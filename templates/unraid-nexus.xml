<?xml version="1.0"?>
<Container version="2">
  <Name>Nexus</Name>
  <Repository>ghcr.io/martinkeat/nexus:latest</Repository>
  <Registry>https://github.com/martinkeat/nexus/pkgs/container/nexus</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/martinkeat/nexus/issues</Support>
  <Project>https://github.com/martinkeat/nexus</Project>
  <Overview>Nexus is a premium unified media automation platform that consolidates qBittorrent, SABnzbd, Sonarr, Radarr, Lidarr, Whisparr, Prowlarr, Overseerr, FlareSolverr, and FFmpeg-based transcoding behind one beautiful, modern web interface. Managed by a single s6-overlay process supervisor, it provides a centralized control plane for your entire media stack with native GPU acceleration and intelligent service management.&#xD;
&#xD;
[b]Features:[/b]&#xD;
- [b]Unified Dashboard:[/b] Overview of all downloads, media, and service health.&#xD;
- [b]Service Control:[/b] Start, stop, and restart individual services from one UI.&#xD;
- [b]Transcoding Regulariser:[/b] Automated FFmpeg-based transcoding with hardware acceleration.&#xD;
- [b]Single Container:[/b] Drastically reduces resource overhead compared to individual containers.</Overview>
  <Category>MediaApp:Video MediaApp:Music MediaApp:Photos Downloaders: Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/martinkeat/nexus/main/templates/unraid-nexus.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/martinkeat/nexus/main/branding/app-icon-512.png</Icon>
  <ExtraParams>--device /dev/dri:/dev/dri</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <Date>2026-05-13</Date>
  <Changes>[b]Version 0.1.0-alpha[/b]&#xD;
- Initial release with support for 10+ integrated services.&#xD;
- Unified dashboard and health monitoring.&#xD;
- Intel/AMD GPU hardware acceleration support.</Changes>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Unified Media Automation Dashboard</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8080</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>6881</HostPort>
        <ContainerPort>6881</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>6881</HostPort>
        <ContainerPort>6881</ContainerPort>
        <Protocol>udp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/nexus</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/downloads</HostDir>
      <ContainerDir>/downloads</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media_storage/sonarr</HostDir>
      <ContainerDir>/tv</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media_storage/radarr</HostDir>
      <ContainerDir>/movies</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media_storage/lidarr</HostDir>
      <ContainerDir>/music</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media_storage/whisparr</HostDir>
      <ContainerDir>/adult</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/nexus/transcode</HostDir>
      <ContainerDir>/transcode</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>99</Value>
      <Name>PUID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>Europe/London</Value>
      <Name>TZ</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>022</Value>
      <Name>UMASK</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Nexus Web UI" Target="8080" Default="8080" Mode="tcp" Description="The web interface for Nexus." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="BitTorrent Port (TCP)" Target="6881" Default="6881" Mode="tcp" Description="The port used for BitTorrent traffic (TCP)." Type="Port" Display="always" Required="false" Mask="false"/>
  <Config Name="BitTorrent Port (UDP)" Target="6881" Default="6881" Mode="udp" Description="The port used for BitTorrent traffic (UDP)." Type="Port" Display="always" Required="false" Mask="false"/>
  <Config Name="Appdata Config" Target="/config" Default="/mnt/user/appdata/nexus" Mode="rw" Description="Container configuration files." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Downloads Path" Target="/downloads" Default="/mnt/user/downloads" Mode="rw" Description="Path to your download folders." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="TV Shows Path" Target="/tv" Default="/mnt/user/media_storage/sonarr" Mode="rw" Description="Path to your TV show library." Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Movies Path" Target="/movies" Default="/mnt/user/media_storage/radarr" Mode="rw" Description="Path to your movie library." Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Music Path" Target="/music" Default="/mnt/user/media_storage/lidarr" Mode="rw" Description="Path to your music library." Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Adult Path" Target="/adult" Default="/mnt/user/media_storage/whisparr" Mode="rw" Description="Path to your adult media library." Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Transcode Cache" Target="/transcode" Default="/mnt/user/appdata/nexus/transcode" Mode="rw" Description="Working directory for transcoding operations." Type="Path" Display="advanced" Required="true" Mask="false"/>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="User ID for file permissions." Type="Variable" Display="advanced" Required="true" Mask="false"/>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID for file permissions." Type="Variable" Display="advanced" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Europe/London" Mode="" Description="Timezone for the container." Type="Variable" Display="advanced" Required="true" Mask="false"/>
</Container>
